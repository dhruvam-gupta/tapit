<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TapIt" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Make status and navigation bars transparent for edge-to-edge -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!--
            API 35+: windowLightStatusBar / windowLightNavigationBar are deprecated.
            The system now auto-adapts icon colours via contrast enforcement.
            enforceStatusBarContrast / enforceNavigationBarContrast = false lets
            enableEdgeToEdge() in MainActivity take full control of icon tinting
            at runtime (which it already does), avoiding any conflict with the theme.
        -->
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>

        <!--
            'always' is required for API 36: content renders under the cutout
            in every orientation, not just short edges.
        -->
        <item name="android:windowLayoutInDisplayCutoutMode">always</item>
    </style>
</resources>
