<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TapIt" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Make status and navigation bars transparent for edge-to-edge -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Force system bar icons to be visible in light mode -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Configure window content to lay out under the display cutout / notch -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
